# Localhost or live site for preview mode
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# Live production URL used by the Guest Links tool (invitation URLs) and the
# RSVP Dashboard (to reach /api/rsvp-data). Falls back to SANITY_STUDIO_PREVIEW_URL
# when unset.
SANITY_STUDIO_SITE_URL=https://nijao.love
SANITY_STUDIO_API_VERSION=2026-03-23
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=your-sanity-studio-hostname
SANITY_AUTH_TOKEN=sanity-auth-token
SANITY_STUDIO_APP_ID=your-sanity-studio-app-id
# RSVP Dashboard — must match RSVP_DASHBOARD_SECRET in frontend/.env.local.
# NOTE: this is bundled into the client-side Studio build, so treat it as
# scraping friction, not a true secret. Studio access is already auth-gated.
SANITY_STUDIO_RSVP_DASHBOARD_SECRET=same-value-as-frontend-RSVP_DASHBOARD_SECRET