# Localhost or live site for preview mode
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# Live production URL used by the Guest Links tool to generate shareable invitation URLs.
# Falls back to SANITY_STUDIO_PREVIEW_URL when unset.
SANITY_STUDIO_SITE_URL=https://nijao.love
SANITY_STUDIO_API_VERSION=2026-03-23
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=your-sanity-studio-hostname
SANITY_AUTH_TOKEN=sanity-auth-token
SANITY_STUDIO_APP_ID=your-sanity-studio-app-id