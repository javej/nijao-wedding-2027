# Wedding Site - Required Environment Variables
# Copy to .env.local and fill in real values

# Sanity CMS (server-side only)
SANITY_API_READ_TOKEN=

# Google Sheets integration (server-side only)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Resend email service (server-side only)
RESEND_API_KEY=

# Sanity webhook HMAC secret (server-side only)
SANITY_WEBHOOK_SECRET=

# Cloudflare Turnstile (server-side only)
TURNSTILE_SECRET_KEY=

# Cloudflare Turnstile (client-side - safe to expose)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
